{
  "scripts": [{
    "in": "example/src/js/main.ts",
    "out": "example/dist/js/scripts.js",
    "options": {
      "sourcemap": true,
      "minify": true,
      "justMinified": false,
      "format": "iife",
      "target": "es2019"
    }
  }, {
    "in": "example/src/js/react-app.jsx",
    "out": "example/dist/js/react-app.js",
    "options": {
      "sourcemap": true,
      "minify": true,
      "format": "iife",
      "target": "es2019"
    }
  }],
  "reactor": [{
    "component": "example/src/js/App.jsx",
    "inject": "app_html",
    "in": "example/src/js/app-hydrate.jsx",
    "out": "example/dist/js/app-hydrate.js",
    "options": {
      "minify": true,
      "target": "es2019"
    }
  }],
  "styles": [{
    "in": "example/src/scss/index.scss",
    "out": "example/dist/css/styles.css",
    "options": {
      "sourcemap": true,
      "minify": true,
      "justMinified": false
    }
  }],
  "markup": {
    "engine": "liquid",
    "in": "example/src/liquid",
    "out": "example/dist",
    "site": {
      "title": "💩 Poops",
      "description": "Straightforward, no-bullshit bundler for the web.",
      "url": "https://stamat.github.io/poops"
    },
    "data": [
      "_data/features.yaml",
      "_data/links.json",
      "_data/poops.yaml",
      "_data/fonts.json"
    ],
    "includePaths": [
      "_layouts",
      "_partials"
    ],
    "timeDateFormat": "MMM D, YYYY",
    "searchIndex": "search-index.json",
    "sitemap": "sitemap.xml"
  },
  "copy": [
    {
      "in": "example/src/static",
      "out": "example/dist"
    }
  ],
  "banner": "/* {{ name }} v{{ version }} | {{ homepage }} | {{ license }} License */",
  "serve" : {
    "port": 4040,
    "base": "/example/dist"
  },
  "livereload": true,
  "watch": [
    "example/src"
  ],
  "includePaths": [
    "node_modules"
  ]
}
